    margin-top: 50px;
    contain: content;
}

.markdown-preview-view > .workspace-leaf {
    margin-top: -30vh;
    height: 100%;
}

.markdown-preview-view.is-readable-line-width > .workspace-leaf {
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
}

.CodeMirror-lines > .workspace-leaf .backlink-pane {
    overflow-y: visible;
}
.is-mobile .mod-active .markdown-source-view {
    overflow: auto;
}
.is-mobile .mod-active .markdown-source-view .cm-content {
    padding-bottom: 1rem !important;
}

.is-mobile .mod-active .markdown-source-view .workspace-leaf,
.is-mobile .mod-active .markdown-source-view .workspace-leaf .backlink-pane {
